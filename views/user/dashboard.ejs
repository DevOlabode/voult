<% layout('layout/boilerplate.ejs') %>

<section class="dashboard">

  <header class="dashboard-header">
    <h1>Dashboard</h1>
    <p class="dashboard-subtext">
      Welcome back, <strong><%= user.name %></strong>
    </p>
  </header>

  <section class="dashboard-section">
    <h2>Overview</h2>
    <div class="dashboard-grid">
      <div class="card">
        <h2>Your apps</h2>
        <p class="muted mb-2">
          You currently have <strong><%= appsCount %></strong> app<%= appsCount === 1 ? '' : 's' %>.
        </p>
        <a href="/apps" class="btn-primary btn-sm">View apps</a>
      </div>

      <div class="card">
        <h2>Account</h2>
        <div class="account-card text-dark">
          <div><strong>Email:</strong> <span class="opacity-75"><%= user.email %></span> </div>
          <div><strong>Plan:</strong> <span class="opacity-75"><%= user.plan %></span></div>
          <div><strong>Joined:</strong> <span class="opacity-75"> <%= user.createdAt.toDateString() %> </span> </div>
        </div>
        <a href="/settings" class="btn-link mt-2">Manage settings →</a>
      </div>
    </div>
  </section>

</section>
