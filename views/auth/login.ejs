<% layout('layout/boilerplate.ejs') %>

<section class="auth-container">
  <h1>Welcome Back</h1>
  <p class="auth-subtext">Login to your developer dashboard.</p>

  <form action="/login" method="POST" class="auth-form">
    <div class="form-group">
      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="you@example.com"
      />
    </div>

    <div class="form-group">
      <label for="loginPassword">Password</label>
      <input
        type="password"
        id="loginPassword"
        name="password"
        required
        placeholder="••••••••"
      />
    </div>

    <div class="auth-actions">
      <a href="/forgot-password" class="auth-link">
        Forgot your password?
      </a>
    </div>

    <button type="submit" class="btn-primary">
      Login
    </button>
  </form>

  <p class="auth-footer">
    Don’t have an account?
    <a href="/register">Create one</a>
  </p>
</section>

<div class="divider">
  <span>or</span>
</div>

<a href="/auth/google" class="google-btn">
  <img src="/images/google-logo.svg" alt="Google" />
  <span>Continue with Google</span>
</a>

<a href="/auth/github" class="github-oauth">
  <span class="icon">
    <svg viewBox="0 0 16 16" width="18" height="18">
      <path fill="currentColor"
        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59..."/>
    </svg>
  </span>
  <span>Continue with GitHub</span>
</a>
