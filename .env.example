# Required for API auth
ENDUSER_JWT_SECRET=your-long-random-secret-for-end-user-jwts
BASE_URL=https://api.voult.dev
DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/voult

# Server
PORT=3000
NODE_ENV=production

# Web app session (developer dashboard)
SECRET=your-long-random-session-secret

# Email (Brevo) — verification, password reset, account lock
BREVO_USER=your-brevo-smtp-user
BREVO_SMTP_KEY=your-brevo-smtp-key

# Optional: force sending emails in development
# SEND_EMAILS=true

# Developer OAuth (optional — for developer login/register)
# JWT_SECRET=your-jwt-secret-for-developer-tokens
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
